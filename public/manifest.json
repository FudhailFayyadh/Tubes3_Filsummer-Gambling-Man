{
  "manifest_version": 3,
  "name": "Judol Detector",
  "version": "1.0",
  "description": "Deteksi konten judi online menggunakan algoritma KMP, Boyer-Moore, dan Regex.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Judol Detector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
